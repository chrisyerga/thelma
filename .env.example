# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
THELMA_MODEL=anthropic/claude-sonnet-4

# Transcription (MLX Whisper on macOS)
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# ElevenLabs narration
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional
# THELMA_ROOT=   # override repo root detection
# THELMA_PYTHON= # override python for scan (defaults to packages/scan/.venv)
